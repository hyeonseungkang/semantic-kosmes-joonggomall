# ─────────────────────────────────────────────
# 공통 설정
# ─────────────────────────────────────────────
NODE_ENV=development

# ─────────────────────────────────────────────
# PostgreSQL (PostGIS)
# ─────────────────────────────────────────────
POSTGRES_USER=kosmes
POSTGRES_PASSWORD=kosmes_secret
POSTGRES_DB=joonggomall
DATABASE_URL=postgresql://kosmes:kosmes_secret@localhost:5432/joonggomall

# ─────────────────────────────────────────────
# AWS OpenSearch
# ─────────────────────────────────────────────
OPENSEARCH_ENDPOINT=http://localhost:9200
OPENSEARCH_INDEX_NAME=listings_semantic
# AWS 관리형 OpenSearch 사용 시 아래 항목 필요
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─────────────────────────────────────────────
# Anthropic Claude
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────
# Cohere (임베딩)
# ─────────────────────────────────────────────
COHERE_API_KEY=

# ─────────────────────────────────────────────
# Redis (BullMQ 큐)
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# 지도 API (Kakao 또는 Naver 중 하나 사용)
# ─────────────────────────────────────────────
KAKAO_MAP_REST_API_KEY=
KAKAO_MAP_JAVASCRIPT_KEY=
# NAVER_MAP_CLIENT_ID=
# NAVER_MAP_CLIENT_SECRET=

# ─────────────────────────────────────────────
# 카카오 알림톡
# ─────────────────────────────────────────────
KAKAO_ALERT_REST_API_KEY=
KAKAO_ALERT_SENDER_KEY=
KAKAO_ALERT_TEMPLATE_ID=

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_SECRET=change_me_to_a_very_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# Web Push (VAPID)
# ─────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ─────────────────────────────────────────────
# AI Microservice (FastAPI)
# ─────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8001

# ─────────────────────────────────────────────
# Backend NestJS 서버 포트
# ─────────────────────────────────────────────
PORT=3000

# ─────────────────────────────────────────────
# AWS S3 (이미지 업로드)
# ─────────────────────────────────────────────
S3_BUCKET_NAME=
S3_REGION=ap-northeast-2
CLOUDFRONT_DOMAIN=
